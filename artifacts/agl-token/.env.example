# ─────────────────────────────────────────────────────────────
# Agunnaya Labs — AGL Token Launch System
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Required: Your deployer wallet private key (starts with 0x)
# Fund this wallet with Base ETH before deploying
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Required: BaseScan API key for contract verification
# Get it at: https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# Optional: Base mainnet RPC (defaults to public endpoint)
# For reliability, use a dedicated node from Alchemy or Infura
BASE_RPC_URL=https://mainnet.base.org

# Optional: Pinata JWT for IPFS uploads (logo + metadata)
# Get it at: https://app.pinata.cloud/keys
PINATA_JWT=YOUR_PINATA_JWT_TOKEN

# Optional: Pinata IPFS gateway
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Optional: Set to base-sepolia for testnet deploys
# NETWORK=base-sepolia
